---
import Layout from '../layouts/Layout.astro';
import { getAllModules, getFeaturedPapers, getRecentPapers, getSiteStats } from '../lib/papers';

const modules = getAllModules();
const featured = getFeaturedPapers(4);
const recent = getRecentPapers(3);
const stats = getSiteStats();
const base = import.meta.env.BASE_URL;
---

<Layout title="首页" description="用于整理不平衡表格数据过采样论文的方法笔记站点。">
  <section class="hero stack">
    <span class="badge">学术知识库 · 表格型不平衡数据 · 过采样方法</span>
    <h1>把过采样论文整理成一个可持续扩展的方法地图。</h1>
    <p class="page-lead">
      这个网站用于整理表格型不平衡数据中的过采样方法。
      每篇论文都会被拆成固定结构，方便按论文、按方法步骤、按创新位置回看和比较。
    </p>
    <div class="actions">
      <a class="button" href={`${base}papers`}>进入论文知识库</a>
      <a class="button secondary" href={`${base}modules`}>按模块比较方法</a>
      <a class="button secondary" href={`${base}guide`}>查看维护说明</a>
    </div>
  </section>

  <section class="grid cols-3" style="margin-top: 1.5rem;">
    <article class="card stat-card">
      <span class="stat-label">已录入论文</span>
      <strong class="stat-value">{stats.paperCount}</strong>
      <p class="muted">持续扩展过采样方法库。</p>
    </article>
    <article class="card stat-card">
      <span class="stat-label">主模块</span>
      <strong class="stat-value">{stats.moduleCount}</strong>
      <p class="muted">用于统一整理论文中的创新位置。</p>
    </article>
    <article class="card stat-card">
      <span class="stat-label">关键词</span>
      <strong class="stat-value">{stats.keywordCount}</strong>
      <p class="muted">用于按方法主题快速回看文献。</p>
    </article>
  </section>

  <section style="margin-top: 2rem;" class="grid cols-2 knowledge-split">
    <article class="detail-block stack">
      <div>
        <h2 class="section-title">使用入口</h2>
        <p class="page-lead">不同入口对应不同的回看方式。</p>
      </div>
      <div class="stack compact-list">
        <a class="link-card" href={`${base}papers`}>
          <strong>论文列表</strong>
          <span>查看每篇论文的核心做法、公式和方法步骤。</span>
        </a>
        <a class="link-card" href={`${base}modules`}>
          <strong>模块索引</strong>
          <span>横向比较同一类创新在不同论文里的实现方式。</span>
        </a>
        <a class="link-card" href={`${base}guide`}>
          <strong>维护说明</strong>
          <span>说明如何继续往这套框架里补充新论文。</span>
        </a>
      </div>
    </article>

    <article class="detail-block stack">
      <div>
        <h2 class="section-title">最近录入</h2>
        <p class="page-lead">这里展示当前优先回看的几篇论文。</p>
      </div>
      <div class="stack compact-list">
        {recent.map((paper) => (
          <a class="link-card" href={`${base}papers/${paper.id}`}>
            <strong>{paper.title}</strong>
            <span>{paper.year} · {paper.innovationSummary}</span>
          </a>
        ))}
      </div>
    </article>
  </section>

  <section style="margin-top: 2rem;" class="stack">
    <div>
      <h2 class="section-title">六个主模块</h2>
      <p class="page-lead">这些模块用于标记论文的主要创新落点。</p>
    </div>
    <div class="grid cols-3">
      {modules.map((module) => (
        <article class="module-card">
          <h3><a href={`${base}modules/${module.slug}`}>{module.name}</a></h3>
          <p>{module.shortDescription}</p>
          <p class="muted">判断问题：{module.guidingQuestion}</p>
        </article>
      ))}
    </div>
  </section>

  <section style="margin-top: 2rem;" class="stack">
    <div>
      <h2 class="section-title">代表性论文</h2>
      <p class="page-lead">这些论文适合作为方法整理示例。</p>
    </div>
    <div class="grid cols-2">
      {featured.map((paper) => (
        <article class="paper-card stack">
          <div>
            <div class="badges">
              <span class="badge">{paper.year}</span>
              <span class="badge">{paper.venue}</span>
              {paper.keywords.slice(0, 2).map((keyword) => <span class="tag">{keyword}</span>)}
            </div>
            <h3 style="margin-top: 0.9rem;"><a href={`${base}papers/${paper.id}`}>{paper.title}</a></h3>
            <p class="muted">{paper.authors}</p>
          </div>
          <p>{paper.innovationSummary}</p>
        </article>
      ))}
    </div>
  </section>
</Layout>
