---
import Layout from '../../layouts/Layout.astro';
import { getAllPapers } from '../../lib/papers';

export function getStaticPaths() {
  return getAllPapers().map((paper) => ({
    params: { id: paper.id },
    props: { paper },
  }));
}

const { paper } = Astro.props;
const base = import.meta.env.BASE_URL;
const figureSrc = paper.figure
  ? (paper.figure.src.startsWith('/') ? `${base}${paper.figure.src.slice(1)}` : `${base}${paper.figure.src}`)
  : null;
---

<Layout title={paper.title} description={paper.innovationSummary}>
  <section class="stack">
    <div class="hero stack">
      <div class="badges">
        <span class="badge">{paper.year}</span>
        <span class="badge">{paper.venue}</span>
        {paper.keywords.map((keyword: string) => <span class="tag">{keyword}</span>)}
      </div>
      <div>
        <h1 class="page-title">{paper.title}</h1>
        <p class="page-lead">{paper.authors}</p>
      </div>
      <div class="summary-grid emphasis-grid">
        <div class="summary-cell">
          <strong>研究问题</strong>
          <p>{paper.problem}</p>
        </div>
        <div class="summary-cell">
          <strong>改进基线</strong>
          <p>{paper.baseline}</p>
        </div>
        <div class="summary-cell">
          <strong>核心创新</strong>
          <p>{paper.innovationSummary}</p>
        </div>
        <div class="summary-cell">
          <strong>适用场景</strong>
          <p>{paper.applicability}</p>
        </div>
      </div>
    </div>

    <div class="grid cols-2">
      <article class="detail-block stack">
        <h2>快速判断</h2>
        <dl class="meta-list">
          <div class="meta-row"><dt>局限</dt><dd>{paper.limitations}</dd></div>
          <div class="meta-row"><dt>引用标记</dt><dd>{paper.citation}</dd></div>
        </dl>
        {paper.links.paper && (
          <div class="actions">
            <a class="button" href={paper.links.paper} target="_blank" rel="noreferrer">打开论文原文</a>
            {paper.links.code && <a class="button secondary" href={paper.links.code} target="_blank" rel="noreferrer">查看代码</a>}
          </div>
        )}
      </article>

      {(paper.figure || paper.memorySummary || paper.memoryAnchors?.length) && (
        <article class="detail-block stack memory-aid-block">
          <div>
            <h2>理解辅助</h2>
            <p class="muted">先看图，再记三步：定轮廓、限位置、清边界。</p>
          </div>

          {paper.figure && figureSrc && (
            <figure class="memory-figure">
              <img src={figureSrc} alt={paper.figure.alt} loading="lazy" />
              <figcaption>{paper.figure.caption}</figcaption>
            </figure>
          )}

          {paper.memorySummary && <div class="memory-callout">{paper.memorySummary}</div>}

          {paper.memoryAnchors && paper.memoryAnchors.length > 0 && (
            <div class="memory-anchor-list">
              {paper.memoryAnchors.map((anchor: string) => <span class="memory-anchor">{anchor}</span>)}
            </div>
          )}
        </article>
      )}
    </div>

    <article class="detail-block stack">
      <h2>阅读备注</h2>
      <ul class="timeline">
        {paper.detailedNotes.map((note: string) => <li>{note}</li>)}
      </ul>
    </article>

    {paper.methodSteps && paper.methodSteps.length > 0 && (
      <article class="detail-block stack">
        <div>
          <h2>方法流程拆解</h2>
          <p class="muted">按论文真正的处理顺序看：先估计密度，再选辅助点，再生成，最后清理。</p>
        </div>
        <div class="grid cols-2">
          {paper.methodSteps.map((step, index) => (
            <article class="card stack numbered-card method-step-card">
              <div class="number-badge">0{index + 1}</div>
              <div>
                <h3>{step.title}</h3>
              </div>
              <div>
                <strong>做什么</strong>
                <p>{step.action}</p>
              </div>
              {step.formula && (
                <div class="formula-block">
                  <strong>公式</strong>
                  <pre>{step.formula}</pre>
                </div>
              )}
              {step.formulaNote && (
                <div>
                  <strong>公式说明</strong>
                  <p>{step.formulaNote}</p>
                </div>
              )}
              <div>
                <strong>这一步的作用</strong>
                <p>{step.purpose}</p>
              </div>
            </article>
          ))}
        </div>
      </article>
    )}
  </section>
</Layout>

